{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TakeOver",
  "version": "1.8.1",
  "identifier": "TakeOver.Systems.App",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "TakeOver",
        "width": 1600,
        "minWidth": 450,
        "height": 900,
        "minHeight": 750,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "backgroundColor": "#0F0000",
        "center": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/codewithali_icon_circle_128x128.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI3MUI1OEJDNUMzNjgxOEMKUldTTWdUWmN2RmdiSi83RXVTaEpPTnJNVkU0UXZtV1UvNWp3NFVwZEFiYWxXbDMvR3A4amlYVDkK",
      "dangerousInsecureTransportProtocol": false,
      "endpoints": [
        "https://www.takeover.systems/api/releases/{{{{target}}}}-{{{{arch}}}}"
      ],
      "windows": {
        "installmode": "passive"
      }
    }
  }
}